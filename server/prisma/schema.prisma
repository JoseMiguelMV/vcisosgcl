generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id           String     @id @default(uuid())
  name         String     @unique
  rut          String
  legalContact String
  configured   Boolean    @default(false)
  users        User[]
  controls     Control[]
  risks        Risk[]
  incidents    Incident[]
  documents    Document[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("USER") // ADMIN, USER
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
}

model Control {
  id        String   @id
  norm      String
  name      String
  state     String
  ley       String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  @@unique([id, companyId])
}

model Risk {
  id          String   @id @default(uuid())
  title       String
  impact      Int
  probability Int
  plan        String
  description String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
}

model Incident {
  id             String        @id @default(uuid())
  title          String
  description    String
  severity       String
  status         String
  date           DateTime      @default(now())
  legalCountdown Int?
  companyId      String
  company        Company       @relation(fields: [companyId], references: [id])
  logs           IncidentLog[]
}

model IncidentLog {
  id         String   @id @default(uuid())
  action     String
  user       String
  date       DateTime @default(now())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id])
}

model Document {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  folder    String
  date      DateTime @default(now())
  size      String
  author    String
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
}
